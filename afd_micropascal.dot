digraph AFD_MicroPascal {

    rankdir=LR;
    fontsize=12;
    labelloc="t";
    label="AFD - Analisador Léxico MicroPascal";

    node [shape=circle, fontname="Arial"];

    // ESTADOS FINAIS (iguais ao código)
    qIDENTIFICADOR [shape=doublecircle];
    qNUMERO_INTEIRO [shape=doublecircle];
    qNUM_REAL [shape=doublecircle];
    qNUMERO_EXPOENTE [shape=doublecircle];

    qDOIS_PONTOS [shape=doublecircle];
    qMENOR [shape=doublecircle];
    qMAIOR [shape=doublecircle];

    ATRIBUICAO [shape=doublecircle];
    MENOR_IGUAL [shape=doublecircle];
    DIFERENTE [shape=doublecircle];
    MAIOR_IGUAL [shape=doublecircle];

    // ESTADO INICIAL
    ponto [shape=point];
    ponto -> q0;

    // IDENTIFICADOR
    q0 -> qIDENTIFICADOR [label="LETRA"];
    qIDENTIFICADOR -> qIDENTIFICADOR [label="LETRA | DIGITO"];

    // NÚMERO INTEIRO
    q0 -> qNUMERO_INTEIRO [label="DIGITO"];
    qNUMERO_INTEIRO -> qNUMERO_INTEIRO [label="DIGITO"];

    // REAL
    qNUMERO_INTEIRO -> qPONTO_DECIMAL [label="."];
    qPONTO_DECIMAL -> qNUM_REAL [label="DIGITO"];
    qNUM_REAL -> qNUM_REAL [label="DIGITO"];

    // EXPOENTE
    qNUM_REAL -> qINICIO_EXPOENTE [label="E | e"];
    qINICIO_EXPOENTE -> qSINAL_EXPOENTE [label="+ | -"];
    qINICIO_EXPOENTE -> qNUMERO_EXPOENTE [label="DIGITO"];
    qSINAL_EXPOENTE -> qNUMERO_EXPOENTE [label="DIGITO"];
    qNUMERO_EXPOENTE -> qNUMERO_EXPOENTE [label="DIGITO"];

    // OPERADORES RELACIONAIS
    q0 -> qDOIS_PONTOS [label=":"];
    qDOIS_PONTOS -> ATRIBUICAO [label="="];

    q0 -> qMENOR [label="<"];
    qMENOR -> MENOR_IGUAL [label="="];
    qMENOR -> DIFERENTE [label=">"];

    q0 -> qMAIOR [label=">"];
    qMAIOR -> MAIOR_IGUAL [label="="];

    // COMENTÁRIO
    q0 -> qCOMENTARIO [label="{"];
    qCOMENTARIO -> qCOMENTARIO [label="qualquer exceto }"];
    qCOMENTARIO -> q0 [label="}"];

}